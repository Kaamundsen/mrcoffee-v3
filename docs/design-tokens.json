{
  "name": "MrCoffee.no – design tokens (Vite/React-referanse)",
  "fonts": {
    "serif": {
      "family": "Cormorant Garamond",
      "weights": "300–700, italic",
      "googleFonts": "https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;0,700;1,300;1,400;1,500;1,600;1,700&display=swap"
    },
    "sans": {
      "family": "Inter",
      "weights": "100–900",
      "googleFonts": "https://fonts.googleapis.com/css2?family=Inter:wght@100..900&display=swap"
    },
    "usage": {
      "headings": "serif",
      "body": "sans",
      "navLinks": "sans, uppercase, wide letter-spacing (tracking-widest / ca. 0.1em)"
    }
  },
  "colors": {
    "chineseBlack": "#0C1519",
    "darkJungle": "#162127",
    "jet": "#3A3534",
    "coffee": "#724B39",
    "antiqueBrass": "#C89F80",
    "cream": "#F8F6EF",
    "creamDark": "#E8E4D9",
    "qualitySectionBg": "#F1E7DF",
    "qualityCardBg": "#EBE2DA",
    "iconAccent": "#C89F80",
    "tasteBærekraftIcon": "Tailwind emerald-600 (skogsgrønn tone)"
  },
  "radii": {
    "button": "9999px (pill / rounded-full)",
    "cardsLarge": "1.5rem (24px, rounded-3xl)",
    "cardsMedium": "1rem (16px, rounded-2xl)",
    "bærekraftGlassPanel": "48px (rounded-[48px])"
  },
  "spacing": {
    "sectionVertical": "6rem mobile, 8rem desktop (py-24 md:py-32)",
    "containerMaxWidth": "80rem (max-w-7xl ≈ 1280px)",
    "containerHorizontalPadding": "1.5rem (px-6)"
  },
  "effects": {
    "glass": {
      "background": "rgba(255,255,255,0.03)",
      "backdropFilter": "blur(12px)",
      "border": "1px solid rgba(255,255,255,0.05)"
    },
    "glassLight": {
      "background": "rgba(255,255,255,0.55)",
      "backdropFilter": "blur(16px)",
      "border": "1px solid rgba(255,255,255,0.3)"
    },
    "atmosphereContactBg": "radial-gradient(circle at 50% -20%, #162127 0%, #0C1519 100%)",
    "heroOverlay": "radial-gradient(ellipse 130% 90% at 0% 100%, rgb(12 21 25 / 0.72) 0%, rgb(12 21 25 / 0.35) 42%, transparent 68%)"
  },
  "buttons": {
    "base": "px-8 py-4, rounded-full, text-sm uppercase, font-semibold, tracking-widest, transition 300ms",
    "primary": { "bg": "#C89F80", "text": "#0C1519", "hoverBg": "#ffffff" },
    "ghost": { "border": "1px solid white", "text": "white", "hoverBg": "rgba(255,255,255,0.1)" },
    "outline": { "border": "1px solid #C89F80", "text": "#C89F80", "hoverBg": "#C89F80", "hoverText": "#0C1519" },
    "outlineDark": { "border": "1px solid rgba(12,21,25,0.3)", "text": "#0C1519", "hoverBg": "#C89F80", "hoverBorder": "#C89F80" }
  },
  "anchors": {
    "kvalitet": "#kvalitet",
    "produkter": "#produkter",
    "alleProdukter": "#alle-produkter",
    "service": "#service",
    "omOss": "#om-oss",
    "baerekraft": "#baerekraft",
    "kontakt": "#kontakt",
    "kaffemaskiner": "#kaffemaskiner",
    "kaffetraktere": "#kaffetraktere",
    "vannmaskiner": "#vannmaskiner"
  }
}
